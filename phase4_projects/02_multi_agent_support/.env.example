# ==================== LLM API Keys ====================

# Zhipu AI (主要推荐，中文支持好)
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# Groq API (备选，免费且快速)
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (用于图像处理)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== Vector Database ====================

# Milvus (向量数据库) - 生产环境推荐
# 文档: https://milvus.io/docs

# Milvus 连接配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Milvus 索引配置
MILVUS_INDEX_TYPE=HNSW  # HNSW (高性能), IVF_FLAT (平衡), FLAT (精确)
MILVUS_EMBEDDING_DIM=768  # 向量维度 (智谱 embedding-2 默认 768)

# Milvus 集合名称前缀
MILVUS_COLLECTION_PREFIX=customer_service_kb

# Milvus Lite 配置（本地开发，无需 Docker）
# true: 使用本地文件模式 (./data/milvus/milvus_lite.db)
# false: 连接到 Milvus 服务器
USE_MILVUS_LITE=true

# Milvus Lite 本地数据库路径
MILVUS_LITE_URI=./data/milvus/milvus_lite.db

# Pinecone API Key (备选向量数据库)
# 获取地址: https://www.pinecone.io/
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_INDEX_NAME=customer-service-kb
# PINECONE_ENVIRONMENT=us-east-1-aws

# ==================== Embeddings ====================

# HuggingFace Embeddings 模型
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HF Mirror (国内用户加速下载)
HF_ENDPOINT=https://hf-mirror.com

# ==================== Hybrid Search (混合检索) ====================

# 是否启用混合检索 (BM25 + Vector)
ENABLE_HYBRID_SEARCH=true

# BM25 权重 (0-1)
BM25_WEIGHT=0.4

# Vector 权重 (0-1)
VECTOR_WEIGHT=0.6

# ==================== LangSmith (可选) ====================

# LangChain API Key (用于 LangSmith 监控)
# 获取地址: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=multi-agent-customer-service

# ==================== Server Config ====================

# 后端服务配置
HOST=0.0.0.0
PORT=8000

# 前端配置
API_BASE_URL=http://127.0.0.1:8000

# ==================== Storage ====================

# 文件上传目录
UPLOAD_DIR=./data/uploads

# 知识库目录
KNOWLEDGE_DIR=./data/knowledge

# ==================== Agent Config ====================

# 质量评分阈值
QUALITY_THRESHOLD=0.7

# 升级人工阈值
ESCALATION_THRESHOLD=0.3

# ==================== LLM API Keys ====================

# Zhipu AI (主要推荐，中文支持好)
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# ==================== Vector Database ====================

# Milvus 集合名称前缀
MILVUS_COLLECTION_PREFIX=enterprise_qa_kb

# Milvus Lite 本地数据库路径
MILVUS_LITE_URI=./data/milvus/milvus_lite.db

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=enterprise_qa_kb

# 强制使用指定向量数据库 (milvus/chroma)
# FORCE_VECTOR_DB=chroma

# ==================== Embeddings ====================

# Embeddings 模型
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HF Mirror (国内用户加速下载)
HF_ENDPOINT=https://hf-mirror.com

# ==================== Hybrid Search ====================

# 启用混合检索 (BM25 + Vector)
ENABLE_HYBRID_SEARCH=true

# BM25 权重 (0-1)
BM25_WEIGHT=0.4

# Vector 权重 (0-1)
VECTOR_WEIGHT=0.6

# BM25 索引持久化目录
BM25_PERSIST_DIR=./data/bm25

# ==================== Query Processor ====================

# 启用查询重写
ENABLE_QUERY_REWRITE=true

# 启用多查询生成
ENABLE_MULTI_QUERY=false

# ==================== Reranker ====================

# 启用 LLM 重排序
ENABLE_LLM_RERANK=true

# 重排序最低分数阈值
RERANK_MIN_SCORE=4.0

# 重排序返回 Top-K
RERANK_TOP_K=5

# ==================== Server Config ====================

# 后端服务
HOST=0.0.0.0
PORT=8000

# 前端 API 地址
API_BASE_URL=http://127.0.0.1:8000

# ==================== Storage ====================

# 文件上传目录
UPLOAD_DIR=./data/uploads

# 知识库目录
KNOWLEDGE_DIR=./data/knowledge

# ==================== Agent Config ====================

# 质量评分阈值
QUALITY_THRESHOLD=0.6

# 知识库类别
KB_CATEGORIES=products,capabilities,company,faq

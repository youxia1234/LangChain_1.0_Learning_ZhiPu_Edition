# ==================== LLM API Keys ====================

# Zhipu AI (主要推荐，中文支持好)
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# Groq API (备选，免费且快速)
# 获取地址: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API (用于图像处理)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== Vector Database ====================

# ChromaDB 配置（本地向量数据库，无需额外安装）
# ChromaDB 会自动将数据持久化到本地目录

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# ChromaDB 集合名称
CHROMA_COLLECTION=customer_service_kb

# ==================== Hybrid Search (混合检索) ====================

# 是否启用混合检索（BM25 + 向量检索）
# true: 启用混合检索（推荐，提升检索质量）
# false: 仅使用向量检索
ENABLE_HYBRID_SEARCH=true

# 混合检索权重配置（两者之和应该为 1.0）
# BM25 权重：关键词精确匹配（专有名词、版本号、代码）
# 建议：技术文档 0.5，产品介绍 0.3，配置手册 0.6
BM25_WEIGHT=0.4

# 向量检索权重：语义理解（同义词、概念查询）
# 建议：技术文档 0.5，产品介绍 0.7，配置手册 0.4
VECTOR_WEIGHT=0.6

# ==================== Embeddings ====================

# HuggingFace Embeddings 模型
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# HF Mirror (国内用户加速下载)
HF_ENDPOINT=https://hf-mirror.com

# ==================== LangSmith (可选) ====================

# LangChain API Key (用于 LangSmith 监控)
# 获取地址: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=multi-agent-customer-service

# ==================== Server Config ====================

# 后端服务配置
HOST=0.0.0.0
PORT=8000

# 前端配置
API_BASE_URL=http://localhost:8000

# ==================== Storage ====================

# 文件上传目录
UPLOAD_DIR=./data/uploads

# 知识库目录
KNOWLEDGE_DIR=./data/knowledge

# ==================== Agent Config ====================

# 质量评分阈值
QUALITY_THRESHOLD=0.7

# 升级人工阈值
ESCALATION_THRESHOLD=0.3
